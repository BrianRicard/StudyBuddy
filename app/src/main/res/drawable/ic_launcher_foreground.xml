<?xml version="1.0" encoding="utf-8"?>
<!--
    StudyBuddy launcher icon foreground — "Professor Hoot"
    An adorable owl wearing a graduation cap, the app's mascot.
    Adaptive icon safe zone: center 66dp circle (radius 33 at 1x).
    Content designed for 108x108 viewport with key features within
    the circular safe zone centered at (54,54).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ===== SMALL SPARKLE STARS (decorative, partially clipped by icon mask) ===== -->
    <!-- Bottom-left sparkle -->
    <path android:pathData="M22,84 L23.2,87.8 L27,88 L23.2,90.2 L22,94 L20.8,90.2 L17,88 L20.8,87.8Z"
        android:fillColor="#FFFDE0"
        android:fillAlpha="0.9" />
    <!-- Bottom-right sparkle -->
    <path android:pathData="M86,80 L87.0,83.2 L90,83 L87.0,85.2 L86,88 L85.0,85.2 L82,83 L85.0,83.2Z"
        android:fillColor="#FFFDE0"
        android:fillAlpha="0.7" />

    <!-- ===== OWL BODY (hint below head — provides depth at icon bottom) ===== -->
    <path android:pathData="M36,92 C36,88 43,84 54,84 C65,84 72,88 72,92 C72,100 65,106 54,106 C43,106 36,100 36,92Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="94"
                android:gradientRadius="22"
                android:startColor="#D4956A"
                android:endColor="#B87848" />
        </aapt:attr>
    </path>

    <!-- ===== OWL HEAD (main shape — large warm amber oval) ===== -->
    <!-- Outer head shape: tall oval centered near (54, 58), y=18 to y=94 -->
    <path android:pathData="M54,18 C70,18 83,32 83,52 C83,72 70,90 54,90 C38,90 25,72 25,52 C25,32 38,18 54,18Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="52"
                android:gradientRadius="42"
                android:startColor="#E8A870"
                android:endColor="#C47840" />
        </aapt:attr>
    </path>

    <!-- ===== FACE DISC (lighter oval — classic owl facial disc) ===== -->
    <path android:pathData="M54,34 C66,34 76,42 76,56 C76,70 66,80 54,80 C42,80 32,70 32,56 C32,42 42,34 54,34Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="56"
                android:gradientRadius="30"
                android:startColor="#FFEBD4"
                android:endColor="#F0CFA8" />
        </aapt:attr>
    </path>

    <!-- ===== LEFT EYE ===== -->
    <!-- White sclera — circle R=12, center (40,52) -->
    <path android:pathData="M40,40 C46.6,40 52,45.4 52,52 C52,58.6 46.6,64 40,64 C33.4,64 28,58.6 28,52 C28,45.4 33.4,40 40,40Z"
        android:fillColor="#FFFFFF" />
    <!-- Amber iris ring — R=10 -->
    <path android:pathData="M40,42 C45.5,42 50,46.5 50,52 C50,57.5 45.5,62 40,62 C34.5,62 30,57.5 30,52 C30,46.5 34.5,42 40,42Z"
        android:fillColor="#FFB84D" />
    <!-- Blue iris — R=8 -->
    <path android:pathData="M40,44 C44.4,44 48,47.6 48,52 C48,56.4 44.4,60 40,60 C35.6,60 32,56.4 32,52 C32,47.6 35.6,44 40,44Z"
        android:fillColor="#4A90D9" />
    <!-- Dark pupil — R=5 -->
    <path android:pathData="M40,47 C42.8,47 45,49.2 45,52 C45,54.8 42.8,57 40,57 C37.2,57 35,54.8 35,52 C35,49.2 37.2,47 40,47Z"
        android:fillColor="#1A1A2E" />
    <!-- White highlight -->
    <path android:pathData="M37,48 C37,46.5 38.4,45.5 40,45.5 C41.6,45.5 42,46.5 42,48 C42,49.5 41.6,50.5 40,50.5 C38.4,50.5 37,49.5 37,48Z"
        android:fillColor="#FFFFFF" />

    <!-- ===== RIGHT EYE ===== -->
    <!-- White sclera — circle R=12, center (68,52) -->
    <path android:pathData="M68,40 C74.6,40 80,45.4 80,52 C80,58.6 74.6,64 68,64 C61.4,64 56,58.6 56,52 C56,45.4 61.4,40 68,40Z"
        android:fillColor="#FFFFFF" />
    <!-- Amber iris ring — R=10 -->
    <path android:pathData="M68,42 C73.5,42 78,46.5 78,52 C78,57.5 73.5,62 68,62 C62.5,62 58,57.5 58,52 C58,46.5 62.5,42 68,42Z"
        android:fillColor="#FFB84D" />
    <!-- Blue iris — R=8 -->
    <path android:pathData="M68,44 C72.4,44 76,47.6 76,52 C76,56.4 72.4,60 68,60 C63.6,60 60,56.4 60,52 C60,47.6 63.6,44 68,44Z"
        android:fillColor="#4A90D9" />
    <!-- Dark pupil — R=5 -->
    <path android:pathData="M68,47 C70.8,47 73,49.2 73,52 C73,54.8 70.8,57 68,57 C65.2,57 63,54.8 63,52 C63,49.2 65.2,47 68,47Z"
        android:fillColor="#1A1A2E" />
    <!-- White highlight -->
    <path android:pathData="M65,48 C65,46.5 66.4,45.5 68,45.5 C69.6,45.5 70,46.5 70,48 C70,49.5 69.6,50.5 68,50.5 C66.4,50.5 65,49.5 65,48Z"
        android:fillColor="#FFFFFF" />

    <!-- ===== BEAK ===== -->
    <path android:pathData="M51,66 C52.5,64 55.5,64 57,66 L54,73Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="51"
                android:startY="64"
                android:endX="57"
                android:endY="73"
                android:startColor="#FFD177"
                android:endColor="#FFB84D" />
        </aapt:attr>
    </path>

    <!-- ===== BLUSH CHEEKS ===== -->
    <!-- Left blush: below left eye -->
    <path android:pathData="M30,66 C30,62 33.4,60 37,60 C40.6,60 44,62 44,66 C44,70 40.6,72 37,72 C33.4,72 30,70 30,66Z"
        android:fillColor="#50FF9A80" />
    <!-- Right blush: below right eye -->
    <path android:pathData="M64,66 C64,62 67.4,60 71,60 C74.6,60 78,62 78,66 C78,70 74.6,72 71,72 C67.4,72 64,70 64,66Z"
        android:fillColor="#50FF9A80" />

    <!-- ===== GRADUATION CAP ===== -->
    <!-- Crown band — sits on head at top -->
    <path android:pathData="M42,40 L66,40 L66,28 L42,28Z"
        android:fillColor="#1A1A2E" />
    <!-- Mortarboard flat top — extends beyond crown -->
    <path android:pathData="M30,32 L78,32 L78,28 L30,28Z"
        android:fillColor="#232340" />
    <!-- Cap top button -->
    <path android:pathData="M52,28 L56,28 L56,22 L52,22Z"
        android:fillColor="#1A1A2E" />
    <!-- Tassel string — from right edge of board down -->
    <path android:pathData="M78,30 L84,44"
        android:strokeColor="#FFB84D"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000" />
    <!-- Tassel ball -->
    <path android:pathData="M84,44 C84,40.7 87.3,40 84,44Z"
        android:fillColor="#FFB84D" />
    <path android:pathData="M81,44 C81,40.7 87,40.7 87,44 C87,47.3 81,47.3 81,44Z"
        android:fillColor="#FFB84D" />

</vector>
