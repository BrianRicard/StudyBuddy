    <path android:pathData="M100,106 C131,106 156,131 156,162 C156,193 131,218 100,218 C69,218 44,193 44,162 C44,131 69,106 100,106Z"
        android:fillColor="#FFD700"
        android:fillAlpha="0.06" />
    <!-- Glow ring 2 -->
    <path android:pathData="M100,96 C138,96 169,127 169,165 C169,203 138,234 100,234 C62,234 31,203 31,165 C31,127 62,96 100,96Z"
        android:fillColor="#FFD700"
        android:fillAlpha="0.04" />
    <!-- Small gold dot accents (floating sparkle dots) -->
    <path android:pathData="M46,80 C46,77 49,77 49,80 C49,83 46,83 46,80Z"
        android:fillColor="#FFD700"
        android:fillAlpha="0.6" />
    <path android:pathData="M154,75 C154,72 157,72 157,75 C157,78 154,78 154,75Z"
        android:fillColor="#FFD700"
        android:fillAlpha="0.5" />
    <path android:pathData="M38,115 C38,113 40,113 40,115 C40,117 38,117 38,115Z"
        android:fillColor="#FFD700"
        android:fillAlpha="0.4" />
    <path android:pathData="M162,120 C162,118 164,118 164,120 C164,122 162,122 162,120Z"
        android:fillColor="#FFD700"
        android:fillAlpha="0.4" />

    <!-- Trophy drop shadow -->
    <path android:pathData="M62,186 C62,184 78,182 100,182 C122,182 138,184 138,186 C138,190 122,192 100,192 C78,192 62,190 62,186Z"
        android:fillColor="#1A1A2E"
        android:fillAlpha="0.15" />

    <!-- ===== TROPHY BASE / PEDESTAL ===== -->
    <!-- Base bottom flat -->
    <path android:pathData="M62,180 L138,180 L138,172 L62,172Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="62"
                android:startY="176"
                android:endX="138"
                android:endY="176"
                android:startColor="#E8A800"
                android:endColor="#C88000" />
        </aapt:attr>
    </path>
    <!-- Base foot highlight top edge -->
    <path android:pathData="M62,172 L138,172"
        android:strokeColor="#FFE840"
        android:strokeWidth="2"
        android:fillColor="#00000000"
        android:strokeAlpha="0.5" />

    <!-- Pedestal column -->
    <path android:pathData="M84,172 L116,172 L116,148 L84,148Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="84"
                android:startY="160"
                android:endX="116"
                android:endY="160"
                android:startColor="#FFD166"
                android:endColor="#D49000" />
        </aapt:attr>
    </path>

    <!-- ===== CUP SHAPE ===== -->
    <!-- Cup main body (front face) -->
    <path android:pathData="M58,50 C58,46 70,42 100,42 C130,42 142,46 142,50 L155,115 C155,128 135,140 100,140 C65,140 45,128 45,115Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="45"
                android:startY="42"
                android:endX="155"
                android:endY="140"
                android:startColor="#FFD166"
                android:endColor="#D49000" />
        </aapt:attr>
    </path>

