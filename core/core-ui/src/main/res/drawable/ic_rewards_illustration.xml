    <path android:pathData="M62,60 L130,60 L148,110 C148,124 130,136 100,136 C70,136 52,124 52,110Z"
        android:fillColor="#C88000"
        android:fillAlpha="0.25" />

    <!-- Cup inner glow highlight (bright area at top inside) -->
    <path android:pathData="M70,55 C80,50 120,50 130,55 L135,75 C125,68 120,62 100,62 C80,62 75,68 65,75Z"
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.22" />

    <!-- Cup top rim -->
    <path android:pathData="M58,50 C58,44 76,38 100,38 C124,38 142,44 142,50 C142,56 124,60 100,60 C76,60 58,56 58,50Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="100"
                android:centerY="50"
                android:gradientRadius="44"
                android:startColor="#FFE840"
                android:endColor="#E8B800" />
        </aapt:attr>
    </path>

    <!-- Pedestal collar (where cup meets pedestal) -->
    <path android:pathData="M78,140 C78,136 86,132 100,132 C114,132 122,136 122,140 L122,148 C122,152 114,154 100,154 C86,154 78,152 78,148Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="78"
                android:startY="143"
                android:endX="122"
                android:endY="143"
                android:startColor="#FFD166"
                android:endColor="#C88000" />
        </aapt:attr>
    </path>

    <!-- ===== LEFT HANDLE ===== -->
    <!-- Handle outer shape -->
    <path android:pathData="M58,55 C40,55 30,70 30,90 C30,110 40,125 58,125 L58,118 C46,118 38,108 38,90 C38,72 46,62 58,62Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="30"
                android:startY="90"
                android:endX="58"
                android:endY="90"
                android:startColor="#E8A800"
                android:endColor="#C88000" />
        </aapt:attr>
    </path>
    <!-- Left handle inner highlight -->
    <path android:pathData="M52,62 C42,66 38,76 38,90 C38,104 42,114 52,118"
        android:strokeColor="#FFE840"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:strokeAlpha="0.35" />

    <!-- ===== RIGHT HANDLE ===== -->
    <!-- Handle outer shape -->
    <path android:pathData="M142,55 C160,55 170,70 170,90 C170,110 160,125 142,125 L142,118 C154,118 162,108 162,90 C162,72 154,62 142,62Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="142"
                android:startY="90"
                android:endX="170"
                android:endY="90"
                android:startColor="#FFD166"
                android:endColor="#C88000" />
        </aapt:attr>
    </path>
    <!-- Right handle inner highlight -->
    <path android:pathData="M148,62 C158,66 162,76 162,90 C162,104 158,114 148,118"
        android:strokeColor="#FFE840"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:strokeAlpha="0.35" />

    <!-- ===== STAR EMBLEM (center of cup) ===== -->
    <!-- Star glow halo -->
    <path android:pathData="M100,70 C117,70 131,84 131,101 C131,118 117,132 100,132 C83,132 69,118 69,101 C69,84 83,70 100,70Z"
        android:fillColor="#FFE840"
        android:fillAlpha="0.2" />
