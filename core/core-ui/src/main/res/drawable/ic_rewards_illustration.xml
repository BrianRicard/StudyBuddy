<?xml version="1.0" encoding="utf-8"?>
<!--
    Achievement Trophy (Rewards) feature illustration.
    Style: classic gold trophy cup with handles, star emblem, radial glow,
    and sparkle accents — as seen in the reference.
    200x200dp viewport.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="200"
    android:viewportHeight="200">

    <!-- ===== RADIAL GLOW RINGS (behind trophy) ===== -->
