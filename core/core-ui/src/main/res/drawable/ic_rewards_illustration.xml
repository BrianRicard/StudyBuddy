    <path android:pathData="M100,74 L106.2,92.4 L126,92.4 L110.4,103.6 L116.6,122 L100,111 L83.4,122 L89.6,103.6 L74,92.4 L93.8,92.4Z"
        android:fillColor="#FFFFFF" />
    <!-- Star inner highlight (makes it sparkle) -->
    <path android:pathData="M100,78 L104.8,92.4 L118,92.4 L107.4,100.4 L112,114 L100,106 L88,114 L92.6,100.4 L82,92.4 L95.2,92.4Z"
        android:fillColor="#FFE840"
        android:fillAlpha="0.5" />

    <!-- ===== SPARKLE DECORATIONS ===== -->
    <!-- Large top-right sparkle -->
    <path android:pathData="M158,28 L160,34 L166,34 L161,38 L163,44 L158,40 L153,44 L155,38 L150,34 L156,34Z"
        android:fillColor="#FFD700" />
    <!-- Medium top-left sparkle -->
    <path android:pathData="M42,42 L43.5,47 L49,47 L44.8,50 L46.5,55 L42,52 L37.5,55 L39.2,50 L35,47 L40.5,47Z"
        android:fillColor="#FFD700"
        android:fillAlpha="0.9" />
    <!-- Small lower-right sparkle -->
    <path android:pathData="M162,148 L163.2,151.8 L167,152 L163.2,154.2 L162,158 L160.8,154.2 L157,152 L160.8,151.8Z"
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.8" />

</vector>
